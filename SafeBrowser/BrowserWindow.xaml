<Window x:Class="SafeBrowser.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Safe Browser" WindowState="Maximized"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#0F1923">

  <Grid>
    <!-- WebView2 - הדפדפן המוגן -->
    <wv2:WebView2 x:Name="WebView" />

    <!-- כפתור יציאה נסתר — פינה שמאלית עליונה, 5 לחיצות -->
    <Border Width="50" Height="50" Background="Transparent"
            HorizontalAlignment="Left" VerticalAlignment="Top"
            Cursor="Arrow"
            MouseLeftButtonDown="ExitTrigger_Click"/>

    <!-- שכבת PIN ליציאה -->
    <Grid x:Name="PinOverlay" Visibility="Collapsed"
          Background="#CC000000">
      <Border Background="#1A2D45" CornerRadius="16" 
              Width="320" Padding="36" VerticalAlignment="Center"
              HorizontalAlignment="Center" FlowDirection="RightToLeft">
        <StackPanel>
          <TextBlock Text="🔐" FontSize="36" HorizontalAlignment="Center"/>
          <TextBlock Text="יציאה מוגנת" FontSize="20" FontWeight="Bold"
                     Foreground="#4FC3F7" HorizontalAlignment="Center" Margin="0,8,0,4"/>
          <TextBlock Text="הכנס קוד נעילה כדי לסגור"
                     Foreground="#78909C" FontSize="13" HorizontalAlignment="Center"
                     Margin="0,0,0,20"/>
          <PasswordBox x:Name="PinInput" 
                       Background="#0F2A3F" Foreground="White"
                       BorderBrush="#4FC3F7" BorderThickness="1"
                       Padding="12,10" FontSize="22"
                       HorizontalContentAlignment="Center"
                       Margin="0,0,0,8"
                       KeyDown="PinInput_KeyDown"/>
          <TextBlock x:Name="PinError" Foreground="#EF5350" 
                     FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,12"/>
          <Button Content="✓  אישור" Style="{StaticResource PrimaryButton}"
                  Height="42" Margin="0,0,0,8" Click="ConfirmPin_Click"/>
          <Button Content="ביטול — חזרה לאתר" Height="38"
                  Background="Transparent" Foreground="#78909C"
                  BorderBrush="#37474F" BorderThickness="1"
                  Cursor="Hand" Click="CancelPin_Click"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
